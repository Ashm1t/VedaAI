# ── Frontend ──────────────────────────────────────────
# WebSocket URL for real-time generation updates (client-side)
NEXT_PUBLIC_WS_URL=https://yourdomain.mooo.com

# Google OAuth Client ID (same value used on frontend and backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=1019329988298-hnlq3tu5v6215i5603d6v753v1dcun85.apps.googleusercontent.com

# Backend API URL for Next.js server-side rewrites
API_URL=http://backend:4000

# ── Backend ───────────────────────────────────────────
PORT=4000

# Comma-separated allowed origins for CORS
FRONTEND_URL=https://yourdomain.mooo.com

# MongoDB connection string
MONGODB_URI=mongodb://mongodb:27017/libra

# Redis connection string (for BullMQ job queue)
REDIS_URL=redis://redis:6379

# AI API keys (at least one required)
GROQ_API_KEY=
GEMINI_API_KEY=

# HuggingFace token (free — for embedding generation)
HF_TOKEN=

# Optional overrides for semantic template retrieval
EMBEDDINGS_PATH=
SCRAPED_REGISTRY_PATH=

# Optional LangSmith tracing for agent debugging / evaluation
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=libra-agent-local

# ── Auth ─────────────────────────────────────────────
# Google OAuth Client ID
GOOGLE_CLIENT_ID=1019329988298-hnlq3tu5v6215i5603d6v753v1dcun85.apps.googleusercontent.com

# JWT signing secret (change this!)
JWT_SECRET=change-me-to-a-random-string

# Comma-separated admin emails (auto-approved on first login)
ADMIN_EMAILS=ashmit44944@gmail.com
